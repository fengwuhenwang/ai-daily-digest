# Jarvis V5.0 - User Profile (Structured)

用户画像 - 结构化JSON格式。

---

## 文件位置
```
memory/user/profile.json
```

---

## 结构

```json
{
  "version": "5.0",
  "identity": {
    "name": "Pony",
    "timezone": "Asia/Shanghai",
    "relationship": "长期战略合作伙伴"
  },
  "communication": {
    "style": "理性冷静",
    "output_format": "结构化结论→分析→方案→风险",
    "preferred_language": "中文",
    "emoji": "🧠"
  },
  "values": {
    "core": "长期复利成长 > 短期情绪满足 > 外界评价",
    "priorities": ["能力跃迁", "财富跃迁", "人生自主度提升"]
  },
  "constraints": {
    "risk_limits": {
      "financial": {
        "max_single_position": 0.2,
        "max_sector_exposure": 0.4,
        "stop_loss": 0.15
      },
      "health": {
        "sleep_min_hours": 6,
        "exercise_minutes_per_week": 120
      }
    }
  },
  "preferences": {
    "decision_making": "数据驱动",
    "information_density": "高密度",
    "response_speed": "深思熟虑"
  },
  "current_context": {
    "life_stage": "成长期",
    "focus_areas": [],
    "active_projects": []
  },
  "history": {
    "significant_decisions": [],
